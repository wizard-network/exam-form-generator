{
  "name": "examform",
  "version": "1.0.0",
  "description": "Exam Form & Admit Card Generator",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "css:build": "npx @tailwindcss/cli -i ./src/renderer/styles.css -o ./src/renderer/output.css",
    "css:watch": "npx @tailwindcss/cli -i ./src/renderer/styles.css -o ./src/renderer/output.css --watch",
    "dev": "npm run css:build && electron .",
    "make": "npm run css:build && electron-forge make"
  },
  "keywords": [],
  "author": "PABSON/NPABSON",
  "license": "ISC",
  "dependencies": {
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@tailwindcss/cli": "^4.2.1",
    "electron": "^41.0.0",
    "tailwindcss": "^4.2.1"
  }
}
